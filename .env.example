# Railway will provide DATABASE_URL when you add a PostgreSQL service.
DATABASE_URL=postgresql://user:password@host:5432/railway

# Create this as a Railway variable. Use a long random value.
ADMIN_TOKEN=replace-with-a-long-random-admin-token

# On Railway, mount a Volume at /data so uploaded worker documents persist.
UPLOAD_DIR=/data/uploads

# Railway sets PORT automatically. Use this locally if needed.
PORT=3000
